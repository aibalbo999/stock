# Local SQLite is easiest for MVP. For Docker Postgres, use:
# postgresql+psycopg://stock_ai:stock_ai_password@localhost:5432/stock_ai
DATABASE_URL=sqlite:///./stock_ai.db
REDIS_URL=redis://localhost:6379/0
VECTOR_DB_PATH=.chroma
USE_CHROMA=false
REPORT_DIR=reports
API_BASE_URL=http://127.0.0.1:8000

# Keep model names configurable because provider naming changes over time.
PRIMARY_LLM_MODEL=gemini-3.5-flash
LOCAL_LLM_MODEL=gemma-4-31b
GOOGLE_API_KEY=
# Optional comma-separated key pool. Takes precedence over GOOGLE_API_KEY.
GOOGLE_API_KEYS=
FUGLE_API_KEY=
FINMIND_TOKEN=

# Candidate promotion confidence thresholds. Defaults are conservative.
CANDIDATE_CONFIDENCE_HIGH_THRESHOLD=75
CANDIDATE_CONFIDENCE_MEDIUM_THRESHOLD=45

# LLM transient error retry policy.
LLM_MAX_RETRIES_PER_KEY=2
LLM_BASE_RETRY_DELAY_SECONDS=0.5
LLM_MAX_RETRY_DELAY_SECONDS=5.0
